#!/bin/sh
set -e
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

cd "$SCRIPT_DIR"

echo "[build] maint (release)"
gcc -std=c11 -O2 -Wall -Wextra -o maint main.c

echo "[build] maint_tests (internal tests)"
gcc -std=c11 -O2 -Wall -Wextra -DENABLE_INTERNAL_TESTS -I"$SCRIPT_DIR" -o maint_tests main.c

echo "Build artifacts:\n  maint\n  maint_tests"
